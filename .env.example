# YouTube: https://www.youtube.com/@rameezimdad (Subscribe for more!)

NODE_ENV=production
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=1

# Generate both with: openssl rand -base64 48
ADMIN_API_KEY=replace-with-a-long-random-bootstrap-key
API_KEY_PEPPER=replace-with-a-different-long-random-secret

DATABASE_PATH=./data/baileys.sqlite
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
LOG_FILE=./logs/app.log
LOG_RETENTION_DAYS=30

# Comma-separated origins allowed from browsers. Use * to allow ANY site/app/localhost
# (API-key auth is the real guard). List specific origins to lock it down instead.
CORS_ORIGINS=*

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=120
ADMIN_RATE_LIMIT_MAX=20
MAX_MEDIA_BYTES=26214400
ALLOW_REMOTE_MEDIA=false
REMOTE_MEDIA_TIMEOUT_MS=15000
QR_WAIT_MS=15000
QR_TTL_MS=60000
RECONNECT_MAX_DELAY_MS=60000
# Skip sends to numbers not on WhatsApp (failed sends to dead numbers look bot-like)
CHECK_RECIPIENT_EXISTS=true

# ===== Anti-ban protection (keeps the WhatsApp number safe) =====
# One message at a time with a RANDOM gap, picked fresh per send (ms). 5-9s looks human.
MESSAGE_DELAY_MIN_MS=5000
MESSAGE_DELAY_MAX_MS=9000
# Show "typing..." briefly before each send, scaled to message length
TYPING_SIMULATION=true
# After every BURST_SIZE messages, take a longer random breather (like a human). 0 = off
BURST_SIZE=20
BURST_PAUSE_MIN_MS=30000
BURST_PAUSE_MAX_MS=60000
# Hard cap on messages per day (UTC). 0 = unlimited (NOT recommended on unwarmed numbers)
DAILY_SEND_LIMIT=500

# Dashboard API sections. Domain shown only when set; IP auto-detects if empty.
PUBLIC_DOMAIN=
PUBLIC_IP=
