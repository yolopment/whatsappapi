{
  "name": "rameez-baileys-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production WhatsApp REST API powered by Baileys and SQLite",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test --test-concurrency=1",
    "check": "node --check src/server.js && node --test --test-concurrency=1"
  },
  "dependencies": {
    "baileys": "7.0.0-rc13",
    "better-sqlite3": "12.4.1",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "express-rate-limit": "8.5.2",
    "file-type": "21.3.4",
    "helmet": "8.1.0",
    "multer": "2.1.1",
    "p-queue": "9.0.1",
    "pino": "10.1.0",
    "pino-http": "11.0.0",
    "qrcode": "1.5.4",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "pino-pretty": "13.1.3",
    "supertest": "7.1.4"
  }
}
